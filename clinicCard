                                stars.forEach((x) => {
                                    const xv = Number(x.getAttribute("data-value"));
                                    if (xv <= v) {
                                        x.classList.add("text-yellow-400");
                                        x.classList.remove("text-gray-300");
                                    } else {
                                        x.classList.remove("text-yellow-400");
                                        x.classList.add("text-gray-300");
                                    }
                                });
                            });
                        });
                        stars.forEach((s) => {
                            s.addEventListener("click", () => {
                                const rating = Number(s.getAttribute("data-value"));
                                if (typeof gtag === "function") {
                                    gtag("event", "rating_star_" + rating, {});
                                }
                                const googleReviewUrl = "https://g.page/r/CdYiqUcDFzDHEBM/review";
                                const feedbackFormUrl = "https://forms.gle/T7wZdgxMuAqUS3vEA";
                                if (rating <= 4) {
                                    window.open(feedbackFormUrl, "_blank");
                                } else {
                                    window.open(googleReviewUrl, "_blank");
                                }
                            });
                        });
                        if (closeBtn) {
                            closeBtn.addEventListener("click", () => {
                                popup.classList.add("hidden");
                                if (typeof gtag === "function") {
                                    gtag("event", "rating_closed", { event_category: "Rating Popup", event_label: "Close Button" });
                                }
                            });
                        }
                    }, 2000);
                }
                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", showPopupAfterDelay);
                } else {
                    showPopupAfterDelay();
                }
            })();
            
            
        </script>
        <script>
function switchTab(tab, el) {
    // Hide all content
    document.querySelectorAll(".tab-content").forEach(c => c.classList.add("hidden"));

    // Show selected
    document.getElementById("tab-" + tab).classList.remove("hidden");

    // Reset tabs
    document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.classList.remove("border-blue-500", "text-blue-600", "border-b-4");
        btn.classList.add("text-gray-500", "border-transparent", "border-b-4");
    });

    // Activate clicked tab
el.classList.add("border-blue-500", "text-blue-600");
el.classList.remove("text-gray-500", "border-transparent");

}
</script>



