        <script>
            (function () {
                if (window.__ratingPopupInit) return;
                window.__ratingPopupInit = true;
                function showPopupAfterDelay() {
                    const popup = document.getElementById("ratingPopup");
                    if (!popup) return;
                    setTimeout(() => {
                        popup.classList.remove("hidden");
                        if (typeof gtag === "function") {
                            gtag("event", "popup_shown", { event_category: "Rating Popup", event_label: "Popup Displayed" });
                        }
                        const starsContainer = popup.querySelector("#stars");
                        const stars = starsContainer ? starsContainer.querySelectorAll("span[data-value]") : [];
