                    "URL:https://stethbook.com/DrSnehaGoudKuna",
                    "END:VCARD",
                ].join("\n");
                const blob = new Blob([vcfData], { type: "text/vcard" });
                const url = URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url;
