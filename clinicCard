        <script>
            function toggleSchedule() {
                document.getElementById("schedule").classList.toggle("hidden");
            }
            function parseTime(t) {
                let parts = t.split(" ");
                let timeStr = parts[0];
                let modifier = parts[1];
                let hours, minutes;
                if (timeStr.includes(":")) {
                    [hours, minutes] = timeStr.split(":").map(Number);
                } else {
                    hours = Number(timeStr);
                    minutes = 0;
                }
                if (modifier && modifier.toUpperCase() === "PM" && hours < 12) {
                    hours += 12;
                }
                if (modifier && modifier.toUpperCase() === "AM" && hours === 12) {
                    hours = 0;
                }
                return hours * 60 + minutes;
            }
            function isWithinTimeRanges(timeRanges) {
                const now = new Date();
                const currentMinutes = now.getHours() * 60 + now.getMinutes();
                for (let range of timeRanges) {
                    const [startStr, endStr] = range.split("–").map((t) => t.trim());
                    const startMinutes = parseTime(startStr);
                    const endMinutes = parseTime(endStr);
                    if (startMinutes <= endMinutes) {
                        if (currentMinutes >= startMinutes && currentMinutes <= endMinutes) {
                            return true;
                        }
                    } else {
                        if (currentMinutes >= startMinutes || currentMinutes <= endMinutes) {
                            return true;
                        }
                    }
                }
                return false;
            }
            const weeklySchedule = { Mon: ["9 AM – 2 PM","4 PM – 8 PM"], Tue: ["9 AM – 2 PM","4 PM – 8 PM"], Wed: ["9 AM – 2 PM","4 PM – 8 PM"], Thu: ["9 AM – 2 PM","4 PM – 8 PM"], Fri: ["9 AM – 2 PM","4 PM – 8 PM"], Sat: ["9 AM – 2 PM","4 PM – 8 PM"], Sun: ["10 AM – 1 PM"] };
            function updateAvailabilityStatus() {
                const now = new Date();
                const days = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
                const currentDay = days[now.getDay()];
                const statusDiv = document.getElementById("availabilityStatus");
                let isAvailable = false;
                if (weeklySchedule[currentDay] && weeklySchedule[currentDay].length > 0) {
                    isAvailable = isWithinTimeRanges(weeklySchedule[currentDay]);
                }
                if (isAvailable) {
                    statusDiv.textContent = "Available Now";
                    statusDiv.className = "text-xs px-2 py-1 rounded-full font-semibold inline-block mb-1 bg-green-100 text-green-600";
                } else {
                    statusDiv.textContent = "Not Available";
                    statusDiv.className = "text-xs px-2 py-1 rounded-full font-semibold inline-block mb-1 bg-gray-200 text-gray-500";
                }
            }
            const fullBioText = `Dr. Sneha Goud Kuna is a compassionate and highly regarded dentist at Happy Dental Hospital, known for her professionalism, skill, and patient-centered approach. Her patients consistently describe her as one of the best doctors in the city, appreciated for her kindness, availability, and genuine care. Many mention that she takes the time to explain every procedure clearly, ensuring comfort and trust throughout the treatment.Over the years, she has built lasting relationships with her patients—some even traveling long distances for follow-ups, reflecting the confidence they have in her expertise. Her work in cosmetic smile design, restorative treatments, and preventive care has earned particular praise for precision and aesthetic results.Reviews often highlight her gentle approach, friendliness, and the positive atmosphere maintained by her team. At Happy Dental Hospital, Dr. Sneha combines modern dental techniques with a personal touch, making every patient feel valued and well cared for from start to finish.`;
            let isBioExpanded = false;
            const wordLimit = 40;
            function initializeBio() {
                const words = fullBioText.split(/\s+/);
                const bioDiv = document.getElementById("bioText");
                const toggleBtn = document.getElementById("toggleMore");
                if (words.length <= wordLimit) {
                    bioDiv.innerHTML = fullBioText;
                    toggleBtn.style.display = "none";
                } else {
                    const limitedText = words.slice(0, wordLimit).join(" ") + "...";
                    bioDiv.innerHTML = limitedText;
                    toggleBtn.style.display = "inline";
                }
            }
            function toggleBio() {
                const bioDiv = document.getElementById("bioText");
                const toggleBtn = document.getElementById("toggleMore");
                if (isBioExpanded) {
                    const words = fullBioText.split(/\s+/);
                    const limitedText = words.slice(0, wordLimit).join(" ") + "...";
                    bioDiv.innerHTML = limitedText;
                    toggleBtn.textContent = "More";
                    gtag("event", "bio_toggle", { doctor: "DrSnehaGoudKuna", state: "less" });
                } else {
                    bioDiv.innerHTML = fullBioText;
                    toggleBtn.textContent = "Less";
                    gtag("event", "bio_toggle", { doctor: "DrSnehaGoudKuna", state: "more" });
                }
                isBioExpanded = !isBioExpanded;
            }
            updateAvailabilityStatus();
            initializeBio();
            function shareCard() {
                const cardLink = "https://stethbook.com/DrSnehaGoudKuna";
                const message = `Check out Dr. Sneha’s WebCard: ${cardLink}`;
